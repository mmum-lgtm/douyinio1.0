---
import Container from "@components/container.astro";
import Faq from "@components/faq.astro";
import Features from "@components/features.astro";
import Hero from "@components/hero.astro";
import Layout from "@layouts/Layout.astro";
// Add new built-in i18n imports
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

// Get current language and create translation function
const safeUrl = Astro.url || new URL('/', Astro.site || 'http://localhost:4321');
const lang = getLangFromUrl(safeUrl);
const t = useTranslations(lang);

// SEO/props: Matched to ui.ts structure (flat keys under language)
const title = t('site.title') ?? 'TikTokio - Libreng TikTok Video Downloader Online Walang Watermark';
const description = t('site.description') ?? 'TikTokio – #1 Libreng TikTok Video Downloader Online Walang Watermark para sa Unli na TikTok downloads. I-download ang mga video sa TikTok gamit ang link sa HD.';
const keywords = t('site.keywords') ?? 'TikTokio, TikTok video downloader online, i-download ang video sa TikTok, Unli TikTok downloads, libreng TikTok downloader, i-save ang mga video sa TikTok, TikTok downloader online';
const image = 'meta/opengraph.webp';
const variant = 'TikTokio';


// Determine text direction based on language (add RTL languages as needed)
const dir = ['vi', 'ar', 'he', 'fa', 'ur'].includes(lang) ? 'rtl' : 'ltr';
---

<Layout title={title} description={description} keywords={keywords} image={image} favicon={favicon} variant={variant} dir={dir}>
  <Hero />
  <Container>
    <Features />
    <Faq />
  </Container>
</Layout>