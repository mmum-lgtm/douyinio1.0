---
import Container from "@components/container.astro";
import Faq from "@components/faq.astro";
import Features from "@components/features.astro";
import Hero from "@components/hero.astro";
import Layout from "@layouts/Layout.astro";
// Add new built-in i18n imports
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

// Get current language and create translation function
const safeUrl = Astro.url || new URL('/', Astro.site || 'http://localhost:4321');
const lang = getLangFromUrl(safeUrl);
const t = useTranslations(lang);

// SEO/props: Matched to ui.ts structure (flat keys under language)
const title = t('site.title') ?? 'TikTokio - Downloader de Vídeo do TikTok Grátis Online Sem Marca d\'Água';
const description = t('site.description') ?? 'TikTokio – O melhor baixador de vídeos do TikTok online e gratuito sem marca d\'água para downloads ilimitados. Baixe vídeos do TikTok com link em HD.';
const keywords = t('site.keywords') ?? 'TikTokio, downloader de vídeo do TikTok online, baixar vídeo do TikTok, downloads ilimitados do TikTok, baixador de TikTok grátis, salvar vídeos do TikTok, TikTok downloader online';
const image = 'meta/opengraph.webp';
const variant = 'TikTokio';


// Determine text direction based on language (add RTL languages as needed)
const dir = ['vi', 'ar', 'he', 'fa', 'ur'].includes(lang) ? 'rtl' : 'ltr';
---

<Layout title={title} description={description} keywords={keywords} image={image} favicon={favicon} variant={variant} dir={dir}>
  <Hero />
  <Container>
    <Features />
    <Faq />
  </Container>
</Layout>