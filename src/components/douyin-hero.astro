---
// src/components/douyin-hero.astro
import DouyinInputScreen from "./DouyinInputScreen";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const safeUrl = Astro.url || new URL('/', Astro.site || 'http://localhost:4321');
const lang = getLangFromUrl(safeUrl);
const t = useTranslations(lang);
---
<div class="relative isolate pt-14 bg-amber-600">
  <div class="sm:pt-10">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-6xl text-center">
        <h1 class="text-2xl font-bold tracking-tight text-black sm:text-4xl">
          Douyin Video Downloader – Download Douyin Videos Without Watermark
        </h1>
        <p class="mt-2 text-lg leading-8 text-gray-900">
          Paste any Douyin link and download the video for free in HD quality.
        </p>
        <DouyinInputScreen client:only="solid-js" />
      </div>
    </div>
  </div>
</div>
